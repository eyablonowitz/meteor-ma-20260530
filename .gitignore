# Python
venv/
.venv/
__pycache__/
*.py[cod]
*.egg-info/
.ipynb_checkpoints/
.mplcache/
.cache/

# local environment variables
.env

# OS
.DS_Store

# Downloaded raw data (re-fetchable via the fetch_* scripts)
data/raw/
data/dyfi/

# Large generated binaries
*.mseed
*.msd

# media / build outputs — regenerable from code, so NOT tracked.
# media/ = Manim renders (rebuild: manim ...); video/*.mp4 = rough_cut.py output;
# video/_rough/ = scratch assembly dir; vo/auditions/ = throwaway auditions.
media/
video/*.mp4
video/*.mp4.part*
video/_rough/
video/manim/previews/
video/assets/vo/auditions/
video/assets/sfx/*.wav      # synthesized SFX, regenerable: python video/sfx.py

# Non-reproducible generated/sourced assets ARE tracked, via Git LFS (see
# .gitattributes): comic/*.png, vo/*.mp3, sfx/*.mp3 (real boom recording),
# music/*.mp3 (ElevenLabs Music outro). Only the synth sfx/*.wav are regenerable.